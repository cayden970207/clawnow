# Supabase (CreateNow auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_URL=

# Hetzner
CLAWNOW_HETZNER_API_TOKEN=
CLAWNOW_HETZNER_LOCATION=sin
CLAWNOW_HETZNER_SERVER_TYPE=cpx31
CLAWNOW_HETZNER_IMAGE=ubuntu-22.04
# Optional: comma-separated SSH key names or IDs from your Hetzner account
CLAWNOW_HETZNER_SSH_KEYS=
CLAWNOW_VM_NAME_PREFIX=clawnow
CLAWNOW_BOOTSTRAP_ASSET_BASE_URL=

# Gateway routing mode
# Default: per-instance HTTPS URL via sslip.io + Caddy on each VM
CLAWNOW_INSTANCE_GATEWAY_TEMPLATE=https://{{IPV4}}.sslip.io
# Temporary fallback (if sslip.io TLS issuance is rate-limited):
# CLAWNOW_INSTANCE_GATEWAY_TEMPLATE=http://{{IPV4}}:18790
CLAWNOW_CONTROL_UI_PATH=clawnow
CLAWNOW_NOVNC_PATH=novnc

# Optional: shared gateway mode
CLAWNOW_GATEWAY_BASE_URL=
CLAWNOW_CONTROL_UI_BASE_URL=
CLAWNOW_NOVNC_BASE_URL=

# Trusted proxy signer
CLAWNOW_CONTROL_UI_ALLOWED_ORIGIN=
CLAWNOW_PROXY_SHARED_SECRET=
CLAWNOW_CONTROL_SESSION_TTL_SECONDS=300
CLAWNOW_NOVNC_TTL_MINUTES=30
# Optional: fixed control-plane gateway device private key.
# If unset, a temporary key is generated at process boot.
# Recommended for stable pairing across redeploys:
# CLAWNOW_GATEWAY_DEVICE_PRIVATE_KEY_B64=$(base64 < /path/to/private-key.pem | tr -d '\n')
CLAWNOW_GATEWAY_DEVICE_PRIVATE_KEY_PEM=
CLAWNOW_GATEWAY_DEVICE_PRIVATE_KEY_B64=
# First-boot package install can be slow on fresh VMs.
CLAWNOW_PROVISIONING_TIMEOUT_SECONDS=900

# Optional VM cloud-init override
CLAWNOW_HETZNER_CLOUD_INIT=
# Default behavior (when empty): uses a compact cloud-init that pulls bootstrap scripts from openclaw main branch URLs.
# Supports placeholders: {{PROXY_SHARED_SECRET}} {{CONTROL_UI_PATH}} {{NOVNC_PATH}} {{USER_ID}} {{INSTANCE_ID}}
CLAWNOW_OPENCLAW_BOOTSTRAP_COMMAND=
# Optional: version passed to bootstrap --openclaw-version (defaults to latest).
# Examples:
# CLAWNOW_OPENCLAW_VERSION=latest
# CLAWNOW_OPENCLAW_VERSION=2026.3.1
# CLAWNOW_OPENCLAW_VERSION=github:openclaw/openclaw#main
CLAWNOW_OPENCLAW_VERSION=
